    local IconLabel = Instance.new("TextLabel")
    IconLabel.Size = UDim2.new(1, 0, 0, 25)
    IconLabel.Position = UDim2.new(0, 0, 0, 5)
    IconLabel.BackgroundTransparency = 1
    IconLabel.Text = icon
    IconLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    IconLabel.Font = Enum.Font.GothamBold
    IconLabel.TextSize = 20
    IconLabel.ZIndex = 5
    IconLabel.Parent = Button

    local NameLabel = Instance.new("TextLabel")
    NameLabel.Size = UDim2.new(1, 0, 0, 20)
    NameLabel.Position = UDim2.new(0, 0, 0, 30)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Text = name
    NameLabel.TextColor3 = Color3.fromRGB(180, 180, 180)
    NameLabel.Font = Enum.Font.Gotham
    NameLabel.TextSize = 11
    NameLabel.ZIndex = 5
    NameLabel.Parent = Button

    -- 😈 เมื่อกดปุ่ม
    Button.MouseButton1Click:Connect(function()
        -- รีเซ็ตปุ่มเก่า
        if selectedButton then
            selectedButton.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            selectedButton:FindFirstChildOfClass("UIStroke").Color = Color3.fromRGB(60, 60, 60)
        end

        -- เลือกปุ่มใหม่
        Button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        ButtonBorder.Color = Color3.fromRGB(200, 0, 0)
        selectedButton = Button

        -- แสดง Tab ที่เลือก
        for _, child in pairs(ContentFrame:GetChildren()) do
            if child:IsA("Frame") then
                child.Visible = false
            end
        end
        tab.Visible = true
    end)

    return Button
end

